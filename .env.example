# OpenMontage - Environment Variables
# Copy this to .env and fill in your keys

# --- Image + video gateway ---
FAL_KEY=                     # FLUX images, Google Veo video, Kling video, MiniMax video, Recraft images
                             # Get one at https://fal.ai/dashboard/keys

# --- Google AI Studio (Gemini) ---
# One key unlocks: Imagen 3 images, Gemini image gen (Pro + Flash), Gemini TTS narration, Gemini video gen
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=              # Primary AI Studio key — preferred over GOOGLE_API_KEY
                             # Unlocks: Imagen 3, Gemini 3 Pro images (paid), Gemini 3.1 Flash images (paid),
                             #          Gemini TTS (voices: Aoede, Charon, Fenrir, Kore, Orbit, Puck, Zephyr, etc.)
                             #          Gemini video generation — Veo 2 / Veo 3 (paid, via generativelanguage.googleapis.com)
GOOGLE_API_KEY=              # Alternative AI Studio key — same endpoint, same capabilities as GEMINI_API_KEY
                             # Unlocks: all of the above (Imagen 3, Gemini Pro/Flash images, TTS, Veo video)
                             # GEMINI_API_KEY takes priority if both are set

# --- Google Cloud (service account) ---
# Required ONLY for Cloud TTS (Chirp 3 HD, Journey, WaveNet voices) and Vertex AI Imagen
# Does NOT work for Gemini TTS or Gemini image generation — use GEMINI_API_KEY for those
GOOGLE_APPLICATION_CREDENTIALS=  # Path to service account JSON file
                                  # e.g. /Users/you/keys/my-project-sa.json
                                  # Set up at: console.cloud.google.com → IAM → Service Accounts

# Piper local TTS voices do not require env vars; install `piper-tts` via pip
# Models are auto-discovered from: ~/.local/share/piper-tts/voices/, ~/.piper/models/, or $PIPER_MODELS_DIR
PIPER_MODELS_DIR=            # Optional: custom path to .onnx voice model files

# --- Voice ---
ELEVENLABS_API_KEY=          # TTS narration, music generation, sound effects
OPENAI_API_KEY=              # OpenAI TTS fallback and DALL-E image generation
XAI_API_KEY=                 # Grok image generation/editing and Grok video generation

# --- Music ---
SUNO_API_KEY=                # Suno AI music generation (full songs, instrumentals, any genre)

# --- Google Flow (browser-based, no paid API) ---
GOOGLE_FLOW_EMAIL=           # Your Google account email used for google.com/flow
                             # Authenticate once: python tools/video/google_flow_setup.py
                             # Unlocks: Veo 3 video gen + Imagen image gen via browser (FREE)

# --- Video Generation ---
HEYGEN_API_KEY=              # HeyGen API + HeyGen MCP server — same key for both
                             # Covers: avatars, talking-head video, lip sync, captions, templates
                             # Also routes to: VEO, Sora, Runway, Kling, Seedance via HeyGen gateway
                             # Get at: https://app.heygen.com/settings?nav=API
RUNWAY_API_KEY=              # Runway Gen-4 (direct API, alternative to fal.ai routing)
HIGGSFIELD_API_KEY=          # Higgsfield Cloud video gen (key — required)
HIGGSFIELD_API_SECRET=       # Higgsfield Cloud video gen (secret — required)
# HIGGSFIELD_KEY=            # Alternative: combined key:secret in one var (key:secret format)
MAGICHOUR_API_KEY=           # Magic Hour AI video effects + face swap + lip sync
VIDEO_GEN_LOCAL_ENABLED=     # Set to "true" for local video gen (needs GPU + diffusers)
VIDEO_GEN_LOCAL_MODEL=       # Local model: wan2.1-1.3b, wan2.1-14b, hunyuan-1.5, ltx2-local, cogvideo-5b
MODAL_LTX2_ENDPOINT_URL=    # Modal self-hosted LTX-2 endpoint (optional)

# --- Stock Media ---
PEXELS_API_KEY=              # Pexels stock footage/images (free)
PIXABAY_API_KEY=             # Pixabay stock footage/images (free)
UNSPLASH_ACCESS_KEY=         # Unsplash stock images (free developer key)
COVERR_API_KEY=              # Coverr premium stock footage (free tier available)
POND5_API_KEY=               # Pond5 public domain footage (free tier)
VIDEVO_API_KEY=              # Videvo stock footage (free tier available)
NARA_API_KEY=                # US National Archives — optional, raises rate limit
NASA_API_KEY=                # NASA media — optional, raises rate limit (free at api.nasa.gov)
# No key needed (free/open): Archive.org, Wikimedia, Library of Congress, ESA, JAXA, NOAA, Dareful, Mixkit

# --- GIF / Overlays ---
GIPHY_API_KEY=               # Giphy animated GIFs for overlays and engagement inserts (free tier: 42 req/hr)

# --- Analysis ---
HF_TOKEN=                    # HuggingFace token — enables speaker diarization in transcriber

# --- Avatar (local installs) ---
# WAV2LIP_PATH=              # Path to cloned Wav2Lip repo (for lip sync)
# SADTALKER_PATH=            # Path to cloned SadTalker repo (for talking head avatars)
